APP_NAME=Desma
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Superadmin “login as” halaman /apps-superadmin-impersonate. Kosong = aktif hanya saat APP_ENV=local.
# SUPERADMIN_IMPERSONATION=true
# URL untuk magic link pelanggan (halaman konfirmasi; bisa sama dengan APP_URL jika full Laravel)
FRONTEND_URL="${APP_URL}"

# Public magic-link routes (see config/rate_limit.php)
# MAGIC_LINK_PER_BOOKING_IP=20
# MAGIC_LINK_PER_IP=100

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Dashboard "Live users by country" (ip-api.com; local/private IPs use fallback below)
# GEOLOCATION_LOCAL_COUNTRY_CODE=ID
# GEOLOCATION_LOG_THROTTLE_MINUTES=360
# GEOLOCATION_DASHBOARD_LOOKBACK_DAYS=30

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=desma
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# GetYourGuide API (integrator)
# GYG_BASE_URL=https://api.getyourguide.com
# GYG_TIMEOUT_SECONDS=30
# GYG_RETRY_MAX=3
# GYG_SYNC_VIA_QUEUE=true
# GYG_JOB_TRIES=5
# GYG_JOB_BACKOFF=15,60,300

# GetYourGuide Supplier API public endpoints (/1/*)
# Required for GYG self-testing tool access.
#
# Multi-tenant SaaS: use ONE platform user for all tenants (GYG calls the same URL + Basic Auth).
# Supplier is taken from /1/suppliers/{supplierId}/... or from a globally unique productId.
# When both are set, Channel Connections / Sync UI auto-marks GetYourGuide as Connected per tenant
# (supplier ID = tenant code). No per-tenant API key is required for inbound Supplier API bookings.
# GYG_SUPPLIER_API_PLATFORM_USERNAME=gyg_platform_user
# GYG_SUPPLIER_API_PLATFORM_PASSWORD=gyg_platform_secret
#
# Legacy: one BasicAuth user bound to a single supplier (still supported).
# Also auto-connects GetYourGuide for the tenant whose code matches SUPPLIER_ID below.
# GYG_SUPPLIER_API_USERNAME=gyg_test_user
# GYG_SUPPLIER_API_PASSWORD=gyg_test_password
# GYG_SUPPLIER_API_SUPPLIER_ID=Abc123
# GYG_SUPPLIER_API_SUPPLIER_NAME=Desma Supplier
# GYG_SUPPLIER_API_DEFAULT_CURRENCY=EUR
# Pricing mode for self-testing: individual | group
# GYG_SUPPLIER_API_PRICING_MODE=individual
# Include prices in availability response (set true for "Availability and price")
# GYG_SUPPLIER_API_INCLUDE_PRICES=true
# Fallback max participants if tour/day capacity is missing
# GYG_SUPPLIER_API_MAX_PARTICIPANTS_DEFAULT=999
# Availability mode: total | by_category
# GYG_SUPPLIER_API_AVAILABILITY_TYPE=total
# Comma-separated individual categories supported by this product setup
# GYG_SUPPLIER_API_SUPPORTED_TICKET_CATEGORIES=ADULT,CHILD
# Comma-separated product IDs accepted by /1/* endpoints
# GYG_SUPPLIER_API_VALID_PRODUCT_IDS=prod123,prod124,prod125,PPYM1U

# Optional: multiple BasicAuth credentials (JSON array)
# Example:
# GYG_SUPPLIER_API_CREDENTIALS=[{"username":"gyg_test_user","password":"gyg_test_password","supplier_id":"Abc123"}]

# Airbnb partner API (OAuth per tenant — platform app credentials)
# AIRBNB_CLIENT_ID=
# AIRBNB_CLIENT_SECRET=
# AIRBNB_REDIRECT_URI="${APP_URL}/apps-travel-agents/airbnb/oauth/callback"
# AIRBNB_WEBHOOK_SECRET=
# AIRBNB_OAUTH_SCOPES="activities_read reservations_read"
# AIRBNB_SYNC_VIA_QUEUE=true
# Webhook: POST /api/v1/webhooks/travel-agents/airbnb  (header X-Tenant-Code + signature)

# Revenue recap default window when no date filter (days) + short result cache (seconds)
# BOOKINGS_RECAP_DEFAULT_DAYS=90
# BOOKINGS_RECAP_CACHE_SECONDS=60

# Page performance caches (seconds)
# PERFORMANCE_TENANT_PICKER_CACHE_SECONDS=300
# PERFORMANCE_ONBOARDING_SUMMARY_CACHE_SECONDS=90
# PERFORMANCE_DASHBOARD_SUMMARY_CACHE_SECONDS=60
# PERFORMANCE_LANDING_PRICING_CACHE_SECONDS=600
# PERFORMANCE_ONBOARDING_SNAPSHOT_DEBOUNCE_SECONDS=300
