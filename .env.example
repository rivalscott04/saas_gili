APP_NAME=Desma
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Superadmin “login as” halaman /apps-superadmin-impersonate. Kosong = aktif hanya saat APP_ENV=local.
# SUPERADMIN_IMPERSONATION=true
# URL untuk magic link pelanggan (halaman konfirmasi; bisa sama dengan APP_URL jika full Laravel)
FRONTEND_URL="${APP_URL}"

# Public magic-link routes (see config/rate_limit.php)
# MAGIC_LINK_PER_BOOKING_IP=20
# MAGIC_LINK_PER_IP=100

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=desma
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# GYG supplier API playground: comma-separated hostnames allowed for “you → GYG” tab
# (outbound calls to supplier-api-gyg-endpoints.yaml). Default: supplier-api.getyourguide.com
# GYG_SUPPLIER_PLAYGROUND_ALLOWED_HOSTS=supplier-api.getyourguide.com
# GYG supplier API playground: default base URL for “you → GYG” UI tab
# Use sandbox first for validation runs.
# GYG_SUPPLIER_PLAYGROUND_DEFAULT_GYG_HOST_BASE_URL=https://supplier-api.getyourguide.com/sandbox

# GetYourGuide API (integrator)
# GYG_BASE_URL=https://api.getyourguide.com
# GYG_TIMEOUT_SECONDS=30
# GYG_RETRY_MAX=3
# GYG_SYNC_VIA_QUEUE=true
# GYG_JOB_TRIES=5
# GYG_JOB_BACKOFF=15,60,300

# GetYourGuide Supplier API public endpoints (/1/*)
# Required for GYG self-testing tool access.
# GYG_SUPPLIER_API_USERNAME=gyg_test_user
# GYG_SUPPLIER_API_PASSWORD=gyg_test_password
# GYG_SUPPLIER_API_SUPPLIER_ID=Abc123
# GYG_SUPPLIER_API_SUPPLIER_NAME=Desma Supplier
# GYG_SUPPLIER_API_DEFAULT_CURRENCY=EUR
# Pricing mode for self-testing: individual | group
# GYG_SUPPLIER_API_PRICING_MODE=individual
# Include prices in availability response (set true for "Availability and price")
# GYG_SUPPLIER_API_INCLUDE_PRICES=true
# Fallback max participants if tour/day capacity is missing
# GYG_SUPPLIER_API_MAX_PARTICIPANTS_DEFAULT=999
# Availability mode: total | by_category
# GYG_SUPPLIER_API_AVAILABILITY_TYPE=total
# Comma-separated individual categories supported by this product setup
# GYG_SUPPLIER_API_SUPPORTED_TICKET_CATEGORIES=ADULT,CHILD
# Comma-separated product IDs accepted by /1/* endpoints
# GYG_SUPPLIER_API_VALID_PRODUCT_IDS=prod123,prod124,PPYM1U
